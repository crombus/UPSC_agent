# ─────────────────────────────────────────────
#  UPSC Agent — Environment Variables
#  Copy this to .env and fill in your keys.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────

# ── LLM Provider (pick one) ──────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...

# ── Azure AI Foundry (if using Foundry) ──────
AZURE_FOUNDRY_ENDPOINT=https://<your-project>.openai.azure.com/
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_FOUNDRY_CHAT_DEPLOYMENT=gpt-4.1

# ── Azure OpenAI (if using Azure directly) ───
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── Web Search ───────────────────────────────
# Tavily: AI-powered search with citations (recommended)
# Get free key at https://tavily.com
TAVILY_API_KEY=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
# If not set, DuckDuckGo is used automatically (no key needed)

# ── Vector DB ────────────────────────────────
CHROMA_PERSIST_DIR=./vectordb/static
CHROMA_DYNAMIC_DIR=./vectordb/dynamic
